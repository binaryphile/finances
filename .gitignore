# See README.md "Privacy rule" for the project-level rule this enforces.
*.csv
*.tsv
*.xls
*.xlsx
*.ods
*.ofx
*.qfx
*.qif
*.pdf

# Conventional locations for personal/working files that stay local-only.
private/
data/
personal/
scratch/

# Editor / OS noise
.direnv/
.envrc.local
.DS_Store
*.swp
